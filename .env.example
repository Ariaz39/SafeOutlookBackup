# --- CONFIGURACIÓN DE RUTAS ---
# Directorio donde están los archivos PST originales
PST_SOURCE_DIR="$env:USERPROFILE\Documents\Archivos de Outlook"

# --- CONFIGURACIÓN MEGA (Respaldo Secundario) ---
# Cuenta de MEGA para la subida (se recomienda una cuenta gratuita dedicada)
MEGA_USER="tu_correo_mega@ejemplo.com"
MEGA_PASS="tu_password_mega"
# Ruta de destino (usar //from/usuario:carpeta para carpetas compartidas)
MEGA_REMOTE_DEST="//from/usuario_pro@ejemplo.com:nombre_carpeta"

# --- CONFIGURACIÓN SMTP (Notificaciones) ---
SMTP_SERVER="smtp.tuempresa.com"
SMTP_PORT=587
SMTP_FROM="backups@tuempresa.com"
SMTP_TO="sistemas@tuempresa.com"
SMTP_USERNAME="backups@tuempresa.com"
SMTP_PASSWORD="tu_password_smtp"
