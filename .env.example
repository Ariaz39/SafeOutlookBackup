# Archivo de ejemplo para las variables de entorno del script de Backup de PST de Outlook
# Renombra este archivo a .env y completa los valores.

# Directorio de origen donde se encuentran los archivos PST de Outlook.
# Puedes usar variables de entorno de Windows (ej. $env:USERPROFILE).
PST_SOURCE_DIR="$env:USERPROFILE\Documents\Archivos de Outlook"

# Configuración del servidor SMTP para el envío de notificaciones.
SMTP_SERVER="mail.tuempresa.com"

# Puerto del servidor SMTP (Recomendado 587 para TLS).
SMTP_PORT=587

# Dirección de correo electrónico del remitente.
SMTP_FROM="info@tuempresa.com"

# Dirección de correo electrónico del destinatario (pueden ser múltiples separadas por coma).
SMTP_TO="sistemas@tuempresa.com"

# Credenciales de autenticación para el servidor SMTP.
SMTP_USERNAME="info@tuempresa.com"
SMTP_PASSWORD="tu_password_aqui"
